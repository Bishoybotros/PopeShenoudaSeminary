@model PopeShenoudaSeminary.ViewModels.StudentDashboardViewModel


@{
    ViewData["Title"] = "لوحة الطالب";
}

@section Styles {
    <style>
        /* ── TOKENS ── */
        :root {
            --navy: #1a3a5c;
            --navy-light: #234d7a;
            --gold: #b8933a;
            --gold-light: #d4a94d;
            --surface: #f5f6f8;
            --card-bg: #ffffff;
            --text-main: #1e2535;
            --text-muted: #6b7280;
            --border: #e4e7ec;
            --success: #16803c;
            --warning: #b45309;
            --radius: 12px;
            --shadow: 0 2px 12px rgba(26,58,92,.08);
        }

        /* ── LAYOUT ── */
        .dash-wrapper {
            background: var(--surface);
            min-height: calc(100vh - 200px);
            padding: 0 0 3rem;
        }

        /* ── HERO BANNER ── */
        .dash-hero {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            position: relative;
            overflow: hidden;
            padding: 2.5rem 0 2rem;
            margin-bottom: 2rem;
        }

            .dash-hero::before {
                content: "";
                position: absolute;
                inset: 0;
                background-image: repeating-linear-gradient( 45deg, transparent, transparent 28px, rgba(255,255,255,.03) 28px, rgba(255,255,255,.03) 30px );
            }

            .dash-hero .container {
                position: relative;
            }

        .student-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: #fff;
            font-weight: 700;
            flex-shrink: 0;
            box-shadow: 0 0 0 4px rgba(184,147,58,.3);
        }

        .student-info h2 {
            color: #fff;
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0 0 .2rem;
        }

        .student-info .badge-year {
            display: inline-block;
            background: var(--gold);
            color: #fff;
            font-size: .75rem;
            padding: .25rem .75rem;
            border-radius: 20px;
            font-weight: 600;
            letter-spacing: .03em;
        }

        .hero-stat {
            text-align: center;
            color: rgba(255,255,255,.7);
        }

            .hero-stat .val {
                display: block;
                font-size: 1.75rem;
                font-weight: 700;
                color: #fff;
                line-height: 1;
            }

            .hero-stat .lbl {
                font-size: .78rem;
                margin-top: .3rem;
            }

        .hero-divider {
            width: 1px;
            height: 48px;
            background: rgba(255,255,255,.15);
            align-self: center;
        }

        /* ── SECTION LABEL ── */
        .section-label {
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: .5rem;
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 1.25rem;
        }

        /* ── CARDS ── */
        .dash-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            overflow: hidden;
            height: 100%;
        }

        .dash-card-header {
            padding: 1rem 1.25rem .75rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: .6rem;
        }

            .dash-card-header .icon {
                width: 34px;
                height: 34px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                flex-shrink: 0;
            }

        .icon-navy {
            background: rgba(26,58,92,.1);
            color: var(--navy);
        }

        .icon-gold {
            background: rgba(184,147,58,.12);
            color: var(--gold);
        }

        .icon-green {
            background: rgba(22,128,60,.1);
            color: var(--success);
        }

        .icon-blue {
            background: rgba(37,99,235,.1);
            color: #2563eb;
        }

        .dash-card-header h5 {
            font-size: .95rem;
            font-weight: 700;
            color: var(--navy);
            margin: 0;
        }

        .dash-card-body {
            padding: 1.25rem;
        }

        /* ── GRADE ROWS ── */
        .grade-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .65rem 0;
            border-bottom: 1px solid var(--border);
        }

            .grade-row:last-child {
                border-bottom: none;
            }

        .grade-subject {
            font-size: .9rem;
            color: var(--text-main);
            font-weight: 500;
        }

        .grade-bar-wrap {
            flex: 1;
            margin: 0 1rem;
            height: 6px;
            background: var(--border);
            border-radius: 99px;
            overflow: hidden;
        }

        .grade-bar {
            height: 100%;
            border-radius: 99px;
            transition: width .6s ease;
        }

        .grade-score {
            font-size: .85rem;
            font-weight: 700;
            min-width: 42px;
            text-align: left;
        }

        /* ── BOOK CARDS ── */
        .book-item {
            display: flex;
            align-items: center;
            gap: .85rem;
            padding: .7rem 0;
            border-bottom: 1px solid var(--border);
        }

            .book-item:last-child {
                border-bottom: none;
            }

        .book-icon {
            width: 42px;
            height: 50px;
            background: rgba(26,58,92,.07);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--navy);
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .book-title {
            font-size: .88rem;
            font-weight: 600;
            color: var(--text-main);
            line-height: 1.3;
        }

        .book-meta {
            font-size: .75rem;
            color: var(--text-muted);
            margin-top: .15rem;
        }

        .btn-dl {
            margin-right: auto;
            flex-shrink: 0;
            font-size: .78rem;
            padding: .3rem .8rem;
            border-radius: 8px;
            border: 1.5px solid var(--navy);
            color: var(--navy);
            background: transparent;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
            white-space: nowrap;
        }

            .btn-dl:hover {
                background: var(--navy);
                color: #fff;
            }

        /* ── SCHEDULE ── */
        .schedule-item {
            display: flex;
            gap: .85rem;
            align-items: flex-start;
            padding: .7rem 0;
            border-bottom: 1px solid var(--border);
        }

            .schedule-item:last-child {
                border-bottom: none;
            }

        .day-badge {
            min-width: 52px;
            text-align: center;
            background: rgba(26,58,92,.07);
            color: var(--navy);
            font-size: .7rem;
            font-weight: 700;
            padding: .35rem .4rem;
            border-radius: 8px;
            line-height: 1.2;
        }

        .schedule-subject {
            font-size: .88rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .schedule-time {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: .1rem;
        }

        /* ── SUBJECTS LIST ── */
        .subject-chip {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .4rem .85rem;
            background: rgba(26,58,92,.06);
            color: var(--navy);
            border-radius: 20px;
            font-size: .82rem;
            font-weight: 600;
            margin: .2rem;
        }

            .subject-chip i {
                font-size: .75rem;
                color: var(--gold);
            }

        /* ── QUICK STATS ── */
        .quick-stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            gap: .85rem;
            box-shadow: var(--shadow);
        }

        .qs-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .qs-val {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--navy);
            line-height: 1;
        }

        .qs-label {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: .15rem;
        }

        /* ── VIEW ALL LINK ── */
        .view-all {
            font-size: .8rem;
            color: var(--gold);
            text-decoration: none;
            font-weight: 600;
            margin-right: auto;
        }

            .view-all:hover {
                color: var(--gold-light);
                text-decoration: underline;
            }
    </style>
}

<div class="dash-wrapper">

    <!-- ══ HERO ══ -->
    <div class="dash-hero">
        <div class="container">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <div class="student-avatar">
                   
                </div>
                <div class="student-info">
                    <p class="section-label mb-1">لوحة الطالب</p>
                    <h2>@Model?.users?.FirstOrDefault()?.FullName</h2>
                    <span class="badge-year">@Model?.Grades?.FirstOrDefault()?.Year</span>
                </div>
                <div class="d-flex gap-4 me-auto flex-wrap">
                    <div class="hero-divider d-none d-md-block"></div>
                    <div class="hero-stat">
                        <span class="val">@Model.Subjects.Count</span>
                        <span class="lbl">مادة مسجّلة</span>
                    </div>
                    <div class="hero-divider d-none d-md-block"></div>
                    <div class="hero-stat">
                        <span class="val">@Model.Books.Count</span>
                        <span class="lbl">كتاب متاح</span>
                    </div>
                    <div class="hero-divider d-none d-md-block"></div>
                    <div class="hero-stat">
                        <span class="val">
                            @(Model.Grades.Any()
                                                        ? Math.Round(Model.Grades.Average(g => g.Score), 1).ToString()
                                                        : "—")
                        </span>
                        <span class="lbl">متوسط الدرجات</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ CONTENT ══ -->
    <div class="container">

        <!-- QUICK STATS ROW -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="quick-stat-card">
                    <div class="qs-icon icon-navy"><i class="bi bi-journal-bookmark-fill"></i></div>
                    <div>
                        <div class="qs-val">@Model.Subjects.Count</div>
                        <div class="qs-label">المواد</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="quick-stat-card">
                    <div class="qs-icon icon-gold"><i class="bi bi-book-fill"></i></div>
                    <div>
                        <div class="qs-val">@Model.Books.Count</div>
                        <div class="qs-label">الكتب</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="quick-stat-card">
                    <div class="qs-icon icon-green"><i class="bi bi-patch-check-fill"></i></div>
                    <div>
                        <div class="qs-val">@Model.Grades.Count(g => g.Score >= 50)</div>
                        <div class="qs-label">مواد ناجحة</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="quick-stat-card">
                    <div class="qs-icon icon-blue"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <div class="qs-val">@Model.Schedule.Count</div>
                        <div class="qs-label">محاضرات الأسبوع</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MAIN GRID -->
        <div class="row g-4">

            <!-- GRADES -->
            <div class="col-lg-6">
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="icon icon-green"><i class="bi bi-bar-chart-fill"></i></div>
                        <h5>درجاتي</h5>
                        <a asp-controller="Student" asp-action="Grades" class="view-all">عرض الكل ←</a>
                    </div>
                    <div class="dash-card-body">
                        @foreach (var g in Model.Grades)
                        {
                            var pct = Math.Min((double)g.Score, 100);
                            var barColor = g.Score >= 85 ? "#16803c"
                            : g.Score >= 60 ? "#b8933a"
                            : "#dc2626";
                            var scoreLabel = g.Score >= 85 ? "ممتاز"
                            : g.Score >= 75 ? "جيد جداً"
                            : g.Score >= 60 ? "جيد"
                            : g.Score >= 50 ? "مقبول"
                            : "راسب";
                            <div class="grade-row">
                                <span class="grade-subject">@g.Subject.Name</span>
                                <div class="grade-bar-wrap">
                                    <div class="grade-bar" style="width:@(pct)%; background:@barColor;"></div>
                                </div>
                                <span class="grade-score" style="color:@barColor">
                                    @g.Score
                                </span>
                            </div>
                        }
                        @if (!Model.Grades.Any())
                        {
                            <p class="text-muted text-center py-3 mb-0">لا توجد درجات متاحة</p>
                        }
                    </div>
                </div>
            </div>

            <!-- BOOKS -->
            <div class="col-lg-6">
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="icon icon-gold"><i class="bi bi-book-fill"></i></div>
                        <h5>كتبي</h5>
                        <a asp-controller="Student" asp-action="Books" class="view-all">عرض الكل ←</a>
                    </div>
                    <div class="dash-card-body">
                        @foreach (var book in Model.Books.Take(5))
                        {
                            <div class="book-item">
                                <div class="book-icon">
                                    <i class="bi bi-file-earmark-pdf-fill"></i>
                                </div>
                                <div style="flex:1; min-width:0;">
                                    <div class="book-title">@book.Title</div>
                                    <div class="book-meta">PDF · للتحميل</div>
                                </div>
                                <a href="@book.FilePath" target="_blank" class="btn-dl">
                                    <i class="bi bi-download"></i> تحميل
                                </a>
                            </div>
                        }
                        @if (!Model.Books.Any())
                        {
                            <p class="text-muted text-center py-3 mb-0">لا توجد كتب متاحة</p>
                        }
                    </div>
                </div>
            </div>

            <!-- SCHEDULE -->
            <div class="col-lg-6">
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="icon icon-blue"><i class="bi bi-calendar-week-fill"></i></div>
                        <h5>جدولي الأسبوعي</h5>
                    </div>
                    <div class="dash-card-body">
                        @foreach (var s in Model.Schedule)
                        {
                            <div class="schedule-item">
                                <div class="day-badge">@s.Day</div>
                                <div>
                                    <div class="schedule-subject">@s.Subject.Name</div>
                                    <div class="schedule-time"><i class="bi bi-clock"></i> @s.Time</div>
                                </div>
                            </div>
                        }
                        @if (!Model.Schedule.Any())
                        {
                            <p class="text-muted text-center py-3 mb-0">لا يوجد جدول دراسي</p>
                        }
                    </div>
                </div>
            </div>

            <!-- SUBJECTS -->
            <div class="col-lg-6">
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="icon icon-navy"><i class="bi bi-journal-bookmark-fill"></i></div>
                        <h5>موادي الدراسية</h5>
                    </div>
                    <div class="dash-card-body">
                        <div class="d-flex flex-wrap pt-1">
                            @foreach (var subject in Model.Subjects)
                            {
                                <span class="subject-chip">
                                    <i class="bi bi-circle-fill"></i>
                                    @subject.Name
                                </span>
                            }
                        </div>
                        @if (!Model.Subjects.Any())
                        {
                            <p class="text-muted text-center py-3 mb-0">لا توجد مواد مسجّلة</p>
                        }
                    </div>
                </div>
            </div>
            <div class="preloader">
                <span>LOADING</span>
                <span class="loader"></span>
            </div>
        </div><!-- /row -->
    </div><!-- /container -->
    
</div>
