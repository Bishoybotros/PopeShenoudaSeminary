@{
    ViewData["Title"] = "الصفحة الرئيسية";
    Layout = "_Layout";
}
<link rel="stylesheet" href="site.css">
<!-- ================================================================== HERO -->
<div class="page-header">
    <div class="container">
        <div class="ph-inner">
            <h2></h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            تسجيل الدخول
                        </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                         
                    </li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<div class="hero-section">
    <div class="hero-section-inner">
        <img src="~/images/slider/slide-1.jpeg" alt="slider-image">
    </div>
</div><!-- ~/hero-section -->
<!-- ================================================================== ABOUT -->

<div class="section about-section">
    <div class="container">
        <div class="transform-content">
            <h2 class="section-title"><span class="text-primary">منارة</span> لاهوتية تعليمية</h2>
            <p>
                تُعد كلية <span class="text-primary">البابا شنودة الثالث الإكليريكية</span> من أهم الكليات
                اللاهوتية، وتقع في شبرا الخيمة داخل
                كنيسة الشهيد العظيم مار جرجس بمقر مطرانية شبرا الخيمة وتوابعها بجوار المطافئ بمحطة كلية
                الزراعة. تأسست الكلية سنة <span class="text-primary">1988</span> ثم أصدر قداسة البابا شنودة
                قرار اعتمادها كلية رسمية عام
                2002م. تقدم الكلية برنامج <span class="text-primary">بكالوريوس العلوم اللاهوتية</span>
                المعتمد من الكنيسة.
            </p>
        </div>

        <div class="plyr__video-embed" id="player">
            <iframe src="https://www.youtube.com/embed/5umtdeIeHJ0?si=T4RZLz8ryrxIJv8s"
                    title="YouTube video player"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>
    </div>
</div><!-- ~/about-section -->
<!-- ================================================================== ACADEMY INFO -->
<div class="section buzzle-section academic-info-section">
    <div class="bz-inner-content">
        <div class="academic-info-section-row student-schedule">
            <div class="image">
                <img src="~/images/about/about-41.jpeg" alt="image">
            </div>
            <div class="text">
                <h2 class="mb-4">مواعيد استقبال الطلبة <br> الجدد</h2>
                <p>
                    <strong>أولاً:</strong> التقديم اعتباراً من اول سبتمبر من كل عام، كل أيام الأسبوع ما عدا
                    الأحد والأربعاء والجمعة من الساعة 5 م حتى 8 م.
                </p>
                <p><strong>ثانياً: المستندات المطلوبة:</strong></p>
                <ul>
                    <li>تزكية أب الاعتراف</li>
                    <li>أصل المؤهل أو مستخرج رسمي</li>
                    <li>صورة البطاقة</li>
                    <li>عدد 6 صور شخصية 4×6</li>
                    <li>دوسية بلاستيك محفظة</li>
                </ul>
            </div>
        </div>
        <div class="academic-info-section-row study-schedule">
            <div class="text">
                <h2 class="mb-4">مواعيد الدراسة ونظام <br> الامتحانات</h2>
                <ul>
                    <li>
                        تبدأ الدراسة يوم رأس السنة القبطية في الأول من أكتوبر من كل عام بحفل كبير يرأسه
                        نيافة الأنبا مرقس.
                    </li>
                    <li>تنتهي الدراسة في النصف الأول من شهر مايو.</li>
                    <li>أيام الدراسة: السبت – الاثنين – الثلاثاء – الخميس من 5 مساءً حتى 9 مساءً.</li>
                    <li>يحرم الطالب من دخول الامتحان إذا تجاوز نسبة الغياب عن 25%.</li>
                    <li>يعتبر الطالب باقياً للإعادة إذا رسب في ثلاث مواد أو أكثر.</li>
                    <li>امتحانات آخر العام في الأول من مايو.</li>
                    <li>امتحانات التخلف لسنوات النقل في أول سبتمبر.</li>
                </ul>
            </div>
            <div class="image">
                <img src="~/images/about/about-40.jpeg" alt="image">
            </div>
        </div>
    </div>
</div><!-- ~/academic-info-section-->
