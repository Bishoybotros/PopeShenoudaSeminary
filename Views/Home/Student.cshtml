@{
    ViewData["Title"] = "عن الكلية";
}

<!-- ===== BREADCRUMB ===== -->
<div class="page-header">
    <div class="container">
        <div class="ph-inner">
            <h2>عن الكلية</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">
                            الصفحة الرئيسية
                        </a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        عن الكلية
                    </li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- ===== ABOUT SECTION ===== -->
<div class="section about-section mt-5">
    <div class="container">
        <div class="section-content content-ttr section-md">
            <h3 class="section-title">
                كلية <strong class="text-primary">البابا شنودة الثالث</strong>
                الإكليريكية والتعليم اللاهوتي المعتمد
            </h3>

            <div class="row">
                <div class="col-md-6">
                    <p>
                        تُعد كلية البابا شنودة الثالث الإكليريكية واحدة من أبرز الكليات اللاهوتية التابعة
                        للكنيسة...
                    </p>
                </div>

                <div class="col-md-6">
                    <p>
                        تأسست الكلية عام 1988، وبدأت مسيرتها التعليمية...
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== IMAGE SECTION ===== -->
<div class="section-content section-wide section-abs-content"
     style="background-image: url('~/images/slider/slide-5.jpeg');">
</div>

<!-- ===== DETAILS ===== -->
<div class="section section-about-pes">
    <div class="container">
        <div class="section-content content-pes">
            <div class="row">
                <div class="col-md-8 offset-lg-2">

                    <h4 class="section-title">
                        <strong class="text-primary">الكلية الإكليريكية</strong>
                        هي كلية لاهوتية كنسية هدفها إعداد الخدام
                    </h4>

                    <!-- نفس القوائم زي ما هي -->
                    <!-- ... -->

                </div>
            </div>

            <img src="~/images/slider/slide-3.jpeg"
                 class="w-100 rounded-4"
                 alt="image" />
        </div>
    </div>
</div>

<!-- ===== ALERT ===== -->
<div class="section duration-alert mt-5">
    <div class="container">
        <div class="alert-item">
            <div class="icon">
                <!-- SVG كما هو -->
            </div>
            <div class="text">
                <h5>مدة الدراسة والدرجة العلمية</h5>
                <p class="mb-0">
                    عدد سنوات الدراسة بالكلية أربع سنوات...
                </p>
            </div>
        </div>
    </div>
</div>
