@model List<PopeShenoudaSeminary.Models.StudentSubjectGrade>

<div class="row">
    <div class="col-md-12">
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">All Students Grades</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-responsive" role="table">
                    <thead>
                        <tr>
                            <th style="width: 10px" scope="col">#</th>
                            <th scope="col">Student</th>
                            <th scope="col">Subject</th>
                            <th scope="col">Score Progress</th>
                            <th style="width: 40px" scope="col">Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int index = 1;
                        }
                        @foreach (var g in Model)
                        {
                            <tr class="align-middle">
                                <td>@(index++).</td>
                                <td>@g.Student.FullName</td>
                                <td>@g.Subject.Name</td>
                                <td>
                                    <div class="progress progress-xs progress-striped active">
                                        <div class="progress-bar text-bg-primary" style="width: @g.Score%"></div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge text-bg-primary">@g.Score%</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="preloader">
            <span>LOADING</span>
            <span class="loader"></span>
        </div>
    </div>

</div>
