        text-transform: uppercase;
        color: rgba(215,184,153,.55);
        padding: 1.25rem 1.25rem .4rem;
    }

    /* ── NAV ITEMS ── */
    .adm-nav {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .adm-nav-item {
        margin: 2px 8px;
    }

    .adm-nav-link {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .62rem .85rem;
        border-radius: 10px;
        color: var(--adm-text);
        text-decoration: none;
        font-size: .875rem;
        font-weight: 500;
        transition: all .15s ease;
    }

        .adm-nav-link:hover {
            background: rgba(198,156,109,.15);
            color: #FFF8F0;
            text-decoration: none;
        }

        .adm-nav-link.active {
            background: rgba(198,156,109,.18);
            color: #FFF8F0;
            font-weight: 600;
            border-right: 3px solid var(--adm-gold);
        }

            .adm-nav-link.active .nav-icon {
                color: var(--adm-gold);
            }

    .nav-icon {
        width: 20px;
