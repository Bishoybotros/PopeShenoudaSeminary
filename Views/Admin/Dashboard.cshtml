        display: flex;
        flex-direction: column;
        position: absolute;
        top: 10;
        right: 0;
        z-index: 1040;
        transition: transform .28s ease;
        box-shadow: 0 0 25px rgba(75,54,33,.18);
    }

    /* For LTR admin layouts swap to left:0 */
    body.admin-ltr .adm-sidebar {
        right: auto;
        left: 0;
    }

    /* ── BRAND AREA ── */
    .adm-brand {
        padding: 1.5rem 1.25rem 1.25rem;
        border-bottom: 1px solid var(--adm-border);
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .adm-brand-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
