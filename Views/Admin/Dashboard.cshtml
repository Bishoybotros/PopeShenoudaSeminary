<!-- Mobile toggle -->
<button class="adm-toggle" onclick="document.querySelector('.adm-sidebar').classList.toggle('open')">
    <i class="bi bi-list"></i>
</button>

<aside class="adm-sidebar">

    <!-- Brand -->
    <div class="adm-brand">
        <div class="adm-brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
        <div>
            <div class="adm-brand-name">كلية البابا شنودة</div>
