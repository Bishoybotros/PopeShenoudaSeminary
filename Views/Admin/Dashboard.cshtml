@*
    Admin Sidebar Navigation — _AdminSidebar.cshtml (or Dashboard.cshtml partial)
    Drop this into your admin layout as @Html.Partial("_AdminSidebar")
*@

@{
    var current = ViewContext.RouteData.Values["controller"]?.ToString();
    var action  = ViewContext.RouteData.Values["action"]?.ToString();

    bool Is(string ctrl, string act = null) =>
        string.Equals(current, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == null || string.Equals(action, act, StringComparison.OrdinalIgnoreCase));
}

