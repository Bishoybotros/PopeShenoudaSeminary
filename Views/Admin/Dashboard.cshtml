<style>
    /* ── COFFEE SIDEBAR TOKENS ── */
    :root {
        --adm-navy: #4B3621; /* Dark Espresso */
        --adm-navy2: #6F4E37; /* Mocha */
        --adm-gold: #C69C6D; /* Caramel */
        --adm-gold2: #D7B899; /* Latte */
