    }

    /* ── BOTTOM SECTION ── */
    .adm-sidebar-footer {
        margin-top: auto;
        padding: 1rem 1.25rem;
        border-top: 1px solid var(--adm-border);
    }

    .adm-logout {
        display: flex;
        align-items: center;
