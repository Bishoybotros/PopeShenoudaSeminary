        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 3px 10px rgba(198,156,109,.35);
    }

    .adm-brand-name {
        font-size: .82rem;
        font-weight: 700;
